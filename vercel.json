{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/gallery", "destination": "/gallery.html" },
    { "source": "/music", "destination": "/music.html" },
    { "source": "/music/:slug", "destination": "/music/:slug.html" },
    { "source": "/videos", "destination": "/videos.html" },
    { "source": "/writing", "destination": "/writing.html" },
    { "source": "/writing/:slug", "destination": "/writing/:slug.html" },
    { "source": "/supply", "destination": "/supply.html" },
    { "source": "/supply/:id", "destination": "/supply/:id.html" }
  ]
}
