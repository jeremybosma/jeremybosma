{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bun run scripts/sync-products.ts && bun run scripts/sync-music.ts && bun run scripts/generate-pages.ts && bun run scripts/generate-sitemap.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sync:instagram:setup": "pip3 install -r scripts/requirements-instagram.txt",
    "sync:instagram": "python3 scripts/sync-instagram-highlights.py",
    "sync:music": "bun run scripts/sync-music.ts",
    "sync:music:playlist": "bun run scripts/sync-music-playlist.ts",
    "instagram:login": "bash scripts/instagram-login.sh",
    "instagram:import": "python3 scripts/import-instagram-session.py"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fulldotdev/sitex": "^0.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.562.0",
    "motion": "^12.26.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "symbols-react": "^1.2.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^16.6.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
